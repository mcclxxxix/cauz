<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agent Principlex — One Bit Per Commit</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=Playfair+Display:wght@700;900&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f5f2ed;
  --surface: #ffffff;
  --border: #d0ccc4;
  --border-strong: #1a1a1a;
  --text: #1a1a1a;
  --text-secondary: #4a4a4a;
  --text-dim: #7a7a7a;
  --red: #c92a2a;
  --red-light: #fff0f0;
  --blue: #1864ab;
  --blue-light: #e7f5ff;
  --green: #2b8a3e;
  --green-light: #ebfbee;
  --amber: #e67700;
  --amber-light: #fff9db;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Source Serif 4’, Georgia, serif;
font-size: 15px;
line-height: 1.7;
}

.header {
padding: 2.5rem 2rem 2rem;
border-bottom: 3px solid var(–border-strong);
}

.header h1 {
font-family: ‘Playfair Display’, serif;
font-weight: 900;
font-size: 2.6rem;
color: var(–text);
letter-spacing: -0.03em;
line-height: 1.1;
}

.header .subtitle {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.8rem;
font-weight: 600;
color: var(–text-secondary);
margin-top: 0.5rem;
text-transform: uppercase;
letter-spacing: 0.06em;
}

.header .issue-tag {
display: inline-block;
margin-top: 0.8rem;
padding: 0.25rem 0.7rem;
background: var(–text);
color: var(–bg);
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
font-weight: 700;
letter-spacing: 0.04em;
}

.nav {
display: flex;
border-bottom: 1px solid var(–border);
position: sticky;
top: 0;
background: var(–bg);
z-index: 100;
}

.nav button {
flex: 1;
background: none;
border: none;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.78rem;
font-weight: 600;
color: var(–text-dim);
padding: 0.9rem 0.5rem;
cursor: pointer;
border-bottom: 3px solid transparent;
transition: all 0.2s;
text-transform: uppercase;
letter-spacing: 0.05em;
}

.nav button:hover { color: var(–text); }
.nav button.active { color: var(–text); border-bottom-color: var(–text); }

.panel { display: none; padding: 2rem; max-width: 900px; }
.panel.active { display: block; animation: fadeUp 0.3s ease; }

@keyframes fadeUp {
from { opacity: 0; transform: translateY(6px); }
to { opacity: 1; transform: translateY(0); }
}

.section-label {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
font-weight: 700;
color: var(–text-secondary);
text-transform: uppercase;
letter-spacing: 0.1em;
margin-bottom: 0.6rem;
}

h2 {
font-family: ‘Playfair Display’, serif;
font-size: 1.6rem;
font-weight: 700;
color: var(–text);
margin-bottom: 1rem;
}

h3 {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.85rem;
font-weight: 700;
color: var(–text);
margin-bottom: 0.4rem;
margin-top: 1.5rem;
}

.net-container {
background: var(–surface);
border: 2px solid var(–border-strong);
padding: 1.5rem;
margin-bottom: 1.5rem;
}

.net-title {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem;
font-weight: 700;
color: var(–text);
text-transform: uppercase;
letter-spacing: 0.1em;
margin-bottom: 1rem;
}

#nn-canvas { width: 100%; height: 340px; display: block; }

.net-legend {
display: flex;
gap: 1.5rem;
margin-top: 1rem;
flex-wrap: wrap;
}

.net-legend-item {
display: flex;
align-items: center;
gap: 0.4rem;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem;
font-weight: 600;
color: var(–text-secondary);
}

.net-legend-dot {
width: 12px;
height: 12px;
border-radius: 50%;
border: 2px solid;
}

.bit-section {
background: var(–surface);
border: 2px solid var(–border-strong);
padding: 1.5rem;
margin-bottom: 1.5rem;
}

.bit-row {
display: flex;
align-items: center;
gap: 1rem;
cursor: pointer;
user-select: none;
}

.bit-square {
width: 48px;
height: 48px;
border: 3px solid var(–border-strong);
display: flex;
align-items: center;
justify-content: center;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 1.4rem;
font-weight: 700;
transition: all 0.2s;
flex-shrink: 0;
}

.bit-square.on { background: var(–text); color: var(–bg); }
.bit-square.off { background: var(–bg); color: var(–text-dim); }

.bit-desc {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.8rem;
color: var(–text);
font-weight: 600;
}

.bit-subdesc {
font-size: 0.75rem;
color: var(–text-secondary);
font-weight: 400;
}

.engram-container {
background: var(–surface);
border: 2px solid var(–border-strong);
padding: 1.5rem;
margin-bottom: 1.5rem;
}

.engram-grid {
display: grid;
grid-template-columns: repeat(16, 1fr);
gap: 2px;
margin-bottom: 1rem;
}

.engram-cell {
aspect-ratio: 1;
border-radius: 1px;
transition: transform 0.15s;
}

.engram-cell:hover { transform: scale(1.8); z-index: 2; position: relative; }

.engram-stats {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1rem;
margin-top: 1rem;
}

.engram-stat {
text-align: center;
padding: 0.8rem;
border: 1px solid var(–border);
}

.engram-stat .val {
font-family: ‘Playfair Display’, serif;
font-size: 1.8rem;
font-weight: 700;
color: var(–text);
}

.engram-stat .label {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem;
font-weight: 600;
color: var(–text-secondary);
text-transform: uppercase;
letter-spacing: 0.08em;
margin-top: 0.2rem;
}

.compare-row {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1rem;
margin-bottom: 1.5rem;
}

@media (max-width: 600px) { .compare-row { grid-template-columns: 1fr; } }

.compare-card {
border: 2px solid var(–border);
padding: 1.2rem;
background: var(–surface);
}

.compare-card h4 {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.75rem;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.08em;
margin-bottom: 0.5rem;
}

.compare-card.factored { border-color: var(–green); }
.compare-card.factored h4 { color: var(–green); }
.compare-card.patchwork { border-color: var(–red); }
.compare-card.patchwork h4 { color: var(–red); }

.mini-grid {
display: grid;
grid-template-columns: repeat(8, 1fr);
gap: 2px;
}

.mini-grid .cell { aspect-ratio: 1; border-radius: 1px; }

.strategy-block {
background: var(–surface);
border: 2px solid var(–border-strong);
border-left: 6px solid var(–text);
padding: 1.5rem;
margin-bottom: 1.2rem;
}

.strategy-block p { color: var(–text); margin-bottom: 0.5rem; }

.strategy-block .callout {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.8rem;
font-weight: 700;
color: var(–text);
background: var(–amber-light);
padding: 0.5rem 0.8rem;
margin-top: 0.8rem;
border-left: 3px solid var(–amber);
}

.verdict {
display: inline-flex;
align-items: center;
gap: 0.4rem;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.75rem;
font-weight: 700;
padding: 0.2rem 0.6rem;
}

.verdict.pass { background: var(–green-light); color: var(–green); }
.verdict.fail { background: var(–red-light); color: var(–red); }

.pipeline-flow {
display: flex;
align-items: center;
gap: 0;
flex-wrap: wrap;
margin: 1.5rem 0;
}

.pipeline-step {
background: var(–surface);
border: 2px solid var(–border-strong);
padding: 0.6rem 1rem;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem;
font-weight: 700;
color: var(–text);
white-space: nowrap;
}

.pipeline-arrow {
font-size: 1.2rem;
color: var(–text-dim);
padding: 0 0.3rem;
}

.econ-row {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1rem;
margin-bottom: 1.5rem;
}

@media (max-width: 600px) { .econ-row { grid-template-columns: 1fr; } }

.econ-card {
background: var(–surface);
border: 2px solid var(–border-strong);
padding: 1.5rem;
}

.econ-card .num {
font-family: ‘Playfair Display’, serif;
font-size: 2.4rem;
font-weight: 900;
color: var(–text);
line-height: 1;
}

.econ-card .num-label {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
font-weight: 700;
color: var(–text-secondary);
text-transform: uppercase;
letter-spacing: 0.08em;
margin-top: 0.4rem;
}

.econ-card .num-note {
font-size: 0.82rem;
color: var(–text-secondary);
margin-top: 0.6rem;
line-height: 1.5;
}

.cost-table {
width: 100%;
border-collapse: collapse;
margin-top: 1.5rem;
font-size: 0.82rem;
}

.cost-table th {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.08em;
color: var(–text);
text-align: left;
padding: 0.6rem 0.8rem;
border-bottom: 2px solid var(–border-strong);
}

.cost-table td {
padding: 0.6rem 0.8rem;
border-bottom: 1px solid var(–border);
color: var(–text-secondary);
}

.cost-table tr:last-child td {
border-bottom: 2px solid var(–border-strong);
font-weight: 600;
color: var(–text);
}

.footer {
padding: 2rem;
border-top: 2px solid var(–border-strong);
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
color: var(–text-secondary);
text-align: center;
}
</style>

</head>
<body>

<div class="header">
  <h1>Agent Principlex</h1>
  <div class="subtitle">One bit per commit · Biaxial autoresearch network</div>
  <div class="issue-tag">karpathy/autoresearch · Principlex #226</div>
</div>

<div class="nav">
  <button class="active" data-tab="network" onclick="switchTab('network')">Neural Net</button>
  <button data-tab="engram" onclick="switchTab('engram')">Engram Map</button>
  <button data-tab="strategy" onclick="switchTab('strategy')">Strategy</button>
  <button data-tab="economics" onclick="switchTab('economics')">Economics</button>
</div>

<!-- NEURAL NET -->

<div id="panel-network" class="panel active">
  <div class="section-label">Example Network</div>
  <h2>Biaxial Neural Network</h2>
  <p style="margin-bottom:1.5rem;color:var(--text-secondary);">A small feedforward network illustrating the Principlex constraint. Each node carries a single-bit annotation: is the learned feature factored (structured, transferable) or patchwork (opaque, fragile)? Filled nodes = factored (1). Hollow dashed nodes = patchwork (0).</p>

  <div class="net-container">
    <div class="net-title">3-Layer Network · d12 Scale · 8 Hidden Units</div>
    <canvas id="nn-canvas"></canvas>
    <div class="net-legend">
      <div class="net-legend-item"><div class="net-legend-dot" style="background:var(--blue);border-color:var(--blue)"></div>Input (4)</div>
      <div class="net-legend-item"><div class="net-legend-dot" style="background:var(--red);border-color:var(--red)"></div>Hidden (8)</div>
      <div class="net-legend-item"><div class="net-legend-dot" style="background:var(--green);border-color:var(--green)"></div>Output (2)</div>
      <div class="net-legend-item"><div class="net-legend-dot" style="background:var(--text);border-color:var(--text)"></div>Factored = 1</div>
      <div class="net-legend-item"><div class="net-legend-dot" style="background:none;border-color:var(--text-dim);border-style:dashed"></div>Patchwork = 0</div>
    </div>
  </div>

  <div class="bit-section">
    <div class="net-title">Commit Gate — Tap to Toggle</div>
    <div class="bit-row" onclick="toggleCommitBit()">
      <div class="bit-square on" id="commit-bit">1</div>
      <div>
        <div class="bit-desc">Factored structure holds across scale?</div>
        <div class="bit-subdesc">Run at d12, render directional colors, repeat at d24. Pattern consistent → 1. Chaotic reorganization → 0. Zero means shelve.</div>
      </div>
    </div>
    <div id="commit-verdict" style="margin-top:1rem;">
      <span class="verdict pass">■ COMMIT — pattern transfers</span>
    </div>
  </div>

  <p style="color:var(--text-secondary);margin-top:1rem;">5 of 8 hidden units show factored features (filled). The remaining 3 are patchwork — they improve val_bpb at d12 but scramble at d24. Under the one-bit policy, this commit passes (majority factored), but patchwork units are flagged for investigation.</p>
</div>

<!-- ENGRAM MAP -->

<div id="panel-engram" class="panel">
  <div class="section-label">Visualization Root</div>
  <h2>Engram Heat Map</h2>
  <p style="margin-bottom:1.5rem;color:var(--text-secondary);">Spatial activation map showing what the model has stored. Hover cells to inspect. A factored model distributes activation evenly; patchwork concentrates it in hot clusters.</p>

  <div class="engram-container">
    <div class="net-title">Engram · Layer 2 · Step 4,200 · d12</div>
    <div class="engram-grid" id="engram-main"></div>
    <div class="engram-stats">
      <div class="engram-stat">
        <div class="val" id="gini-val">—</div>
        <div class="label">Gini Coefficient</div>
      </div>
      <div class="engram-stat">
        <div class="val" id="mass-val">—</div>
        <div class="label">Total Gram-Weight</div>
      </div>
      <div class="engram-stat">
        <div class="val" id="bit-val">—</div>
        <div class="label">Commit Bit</div>
      </div>
    </div>
  </div>

  <div class="section-label" style="margin-top:2rem;">Comparison</div>
  <h3 style="font-family:'Playfair Display',serif;font-size:1.1rem;margin-bottom:1rem;">Factored vs. Patchwork Engrams</h3>

  <div class="compare-row">
    <div class="compare-card factored">
      <h4>Factored (Gini ~0.28) → Bit = 1</h4>
      <div class="mini-grid" id="grid-factored"></div>
      <p style="font-size:0.78rem;color:var(--text-secondary);margin-top:0.6rem;">Evenly distributed activation. Pattern holds at d24. Commit.</p>
    </div>
    <div class="compare-card patchwork">
      <h4>Patchwork (Gini ~0.71) → Bit = 0</h4>
      <div class="mini-grid" id="grid-patchwork"></div>
      <p style="font-size:0.78rem;color:var(--text-secondary);margin-top:0.6rem;">Concentrated hot spots. Scrambles at d24. Shelve.</p>
    </div>
  </div>
</div>

<!-- STRATEGY -->

<div id="panel-strategy" class="panel">
  <div class="section-label">Response to Issue #226</div>
  <h2>One Bit Per Commit</h2>

  <p style="margin-bottom:1.5rem;">The experiment log has two columns of DISCARDED entries, a handful of keepers, and no explanation beyond "the number went down." Improvements transfer from d12 to d24, but nobody can predict what transfers to d96 without re-running everything. Four visualization roots is too much descriptor for a binary signal. Here's the reduced strategy.</p>

  <div class="section-label">The Pipeline</div>
  <div class="pipeline-flow">
    <div class="pipeline-step">Run at d12</div>
    <div class="pipeline-arrow">→</div>
    <div class="pipeline-step">Render dir. colors</div>
    <div class="pipeline-arrow">→</div>
    <div class="pipeline-step">Run at d24</div>
    <div class="pipeline-arrow">→</div>
    <div class="pipeline-step">Pattern holds?</div>
    <div class="pipeline-arrow">→</div>
    <div class="pipeline-step" style="background:var(--text);color:var(--bg);">1 or 0</div>
  </div>

  <div class="strategy-block">
    <h3>Why one bit is enough</h3>
    <p>Factored structure and comprehensibility aren't independent axes — they're the same property at different levels. That's the PicBreeder insight. NEAT-evolved CPPNs don't have organized internals <em>and</em> legibility as separate features. The organization <em>is</em> the legibility. Two axes collapse to one bit.</p>
  </div>

  <div class="strategy-block">
    <h3>The gate</h3>
    <p>One visualization, not four. Directional colors is cheapest — map residual stream vectors to hue. Run at d12, render, run at d24, compare. If the color pattern is consistent across scale, the bit is 1. If it reorganizes chaotically, the bit is 0.</p>
    <div class="callout">Zeros get shelved, not discarded. Flagged for future investigation. But they don't pollute the main branch.</div>
  </div>

  <div class="strategy-block">
    <h3>Engram as secondary check</h3>
    <p>The engram heat map serves as an optional secondary diagnostic. It's not required for the commit decision, but gives a visual on <em>what</em> changed — the bit tells you <em>whether</em> it transferred. Track the Gini coefficient as a running metric. Low Gini = factored. High Gini = patchwork.</p>
  </div>

  <div class="strategy-block">
    <h3>Cost</h3>
    <p>About 5% overhead. One extra render pass per experiment, one scale-up check. Compare to 10–20% for the full four-root regime, or unbounded cost of re-running the entire search when improvements don't transfer to d96.</p>
  </div>

  <div class="strategy-block" style="border-left-color:var(--red);">
    <h3>What this doesn't solve</h3>
    <p>This doesn't explain <em>why</em> a factored improvement works. It only confirms <em>that</em> it transfers. Understanding why lives downstream of having a clean codebase. You can't explain what you can't see.</p>
  </div>
</div>

<!-- ECONOMICS -->

<div id="panel-economics" class="panel">
  <div class="section-label">Cost-Benefit</div>
  <h2>Economic Terms</h2>

  <div class="econ-row">
    <div class="econ-card">
      <div class="num">5%</div>
      <div class="num-label">Compute Overhead</div>
      <div class="num-note">One directional-color render + one d24 scale check per experiment.</div>
    </div>
    <div class="econ-card">
      <div class="num">~15%</div>
      <div class="num-label">Experiments Shelved</div>
      <div class="num-note">Proportion of val_bpb wins that fail the transfer check. Real at d12, gone at d96.</div>
    </div>
    <div class="econ-card">
      <div class="num">3×</div>
      <div class="num-label">Transfer Reliability</div>
      <div class="num-note">Expected d12→d96 transfer improvement for changes passing the one-bit gate.</div>
    </div>
    <div class="econ-card">
      <div class="num">1 bit</div>
      <div class="num-label">Descriptor Cost</div>
      <div class="num-note">Minimum viable annotation. Zero new files. One boolean in the commit message.</div>
    </div>
  </div>

  <table class="cost-table">
    <thead>
      <tr>
        <th>Regime</th>
        <th>Overhead</th>
        <th>Descriptors</th>
        <th>Transfer Signal</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Baseline autoresearch</td>
        <td>0%</td>
        <td>None</td>
        <td>None (re-run everything)</td>
      </tr>
      <tr>
        <td>Full Principlex (4 roots)</td>
        <td>10–20%</td>
        <td>Engram + Cuneiform + Dir. Colors + Tab2Vis</td>
        <td>High (expensive)</td>
      </tr>
      <tr>
        <td>One-Bit Principlex</td>
        <td>~5%</td>
        <td>1 bit + optional engram</td>
        <td>High (cheap)</td>
      </tr>
    </tbody>
  </table>

  <div class="strategy-block" style="margin-top:2rem;border-left-color:var(--green);">
    <p style="font-weight:600;">5% overhead now prevents unbounded re-search costs later. Every patchwork improvement that sneaks into the codebase is technical debt that compounds at scale.</p>
  </div>
</div>

<div class="footer">
  Agent Principlex · MIT Licensed · Credits autoresearch as upstream · Three-file simplicity preserved · One bit per commit
</div>

<script>
function switchTab(tab) {
  document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
  document.querySelector(`.nav button[data-tab="${tab}"]`).classList.add('active');
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + tab).classList.add('active');
  if (tab === 'network') drawNN();
}

let commitBit = true;
function toggleCommitBit() {
  commitBit = !commitBit;
  const el = document.getElementById('commit-bit');
  el.textContent = commitBit ? '1' : '0';
  el.className = 'bit-square ' + (commitBit ? 'on' : 'off');
  document.getElementById('commit-verdict').innerHTML = commitBit
    ? '<span class="verdict pass">■ COMMIT — pattern transfers</span>'
    : '<span class="verdict fail">□ SHELVE — pattern scrambles at d24</span>';
}

function drawNN() {
  const canvas = document.getElementById('nn-canvas');
  const container = canvas.parentElement;
  canvas.width = container.clientWidth - 48;
  canvas.height = 340;
  const ctx = canvas.getContext('2d');
  const W = canvas.width;
  const H = canvas.height;

  const layers = [
    { n: 4, color: '#1864ab', factored: [1,1,1,1] },
    { n: 8, color: '#c92a2a', factored: [1,1,0,1,1,0,1,0] },
    { n: 2, color: '#2b8a3e', factored: [1,1] }
  ];
  const labels = ['INPUT', 'HIDDEN', 'OUTPUT'];

  const padX = 80;
  const layerX = layers.map((_, i) => padX + i * ((W - 2 * padX) / (layers.length - 1)));

  const nodePos = [];
  for (let l = 0; l < layers.length; l++) {
    const pos = [];
    const gap = 38;
    const totalH = (layers[l].n - 1) * gap;
    const startY = (H - totalH) / 2;
    for (let i = 0; i < layers[l].n; i++) {
      pos.push({ x: layerX[l], y: startY + i * gap });
    }
    nodePos.push(pos);
  }

  // Edges
  for (let l = 0; l < layers.length - 1; l++) {
    for (let i = 0; i < nodePos[l].length; i++) {
      for (let j = 0; j < nodePos[l + 1].length; j++) {
        const a = nodePos[l][i];
        const b = nodePos[l + 1][j];
        const both = layers[l].factored[i] && layers[l + 1].factored[j];
        ctx.strokeStyle = both ? 'rgba(26,26,26,0.22)' : 'rgba(26,26,26,0.06)';
        ctx.lineWidth = both ? 1.5 : 0.7;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.stroke();
      }
    }
  }

  // Nodes
  for (let l = 0; l < layers.length; l++) {
    for (let i = 0; i < nodePos[l].length; i++) {
      const p = nodePos[l][i];
      const r = 15;
      const f = layers[l].factored[i];

      ctx.beginPath();
      ctx.arc(p.x, p.y, r, 0, Math.PI * 2);

      if (f) {
        ctx.fillStyle = layers[l].color;
        ctx.fill();
        ctx.fillStyle = '#fff';
      } else {
        ctx.fillStyle = '#f5f2ed';
        ctx.fill();
        ctx.strokeStyle = '#aaa';
        ctx.lineWidth = 2;
        ctx.setLineDash([4, 3]);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = '#999';
      }

      ctx.font = 'bold 12px "IBM Plex Mono", monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(f ? '1' : '0', p.x, p.y);
    }
  }

  // Labels
  ctx.font = 'bold 11px "IBM Plex Mono", monospace';
  ctx.fillStyle = '#1a1a1a';
  ctx.textAlign = 'center';
  for (let l = 0; l < layers.length; l++) {
    ctx.fillText(labels[l], layerX[l], H - 10);
  }
}

function buildEngram(id, mode) {
  const el = document.getElementById(id);
  const size = id === 'engram-main' ? 256 : 64;
  const values = [];

  for (let i = 0; i < size; i++) {
    let v;
    if (mode === 'factored') {
      v = 0.3 + Math.random() * 0.4;
    } else if (mode === 'patchwork') {
      v = Math.random() < 0.15 ? 0.7 + Math.random() * 0.3 : 0.05 + Math.random() * 0.15;
    } else {
      const row = Math.floor(i / 16), col = i % 16;
      const hot = (row > 10 && row < 14 && col > 2 && col < 6);
      v = hot ? 0.6 + Math.random() * 0.4 : 0.15 + Math.random() * 0.45;
    }
    values.push(v);

    const cell = document.createElement('div');
    cell.className = id === 'engram-main' ? 'engram-cell' : 'cell';
    const hue = 220 - v * 220;
    const sat = 55 + v * 35;
    const light = 85 - v * 50;
    cell.style.background = `hsl(${hue}, ${sat}%, ${light}%)`;
    el.appendChild(cell);
  }
  return values;
}

function computeGini(vals) {
  const s = [...vals].sort((a, b) => a - b);
  const n = s.length;
  let sum = 0;
  for (let i = 0; i < n; i++) sum += (2 * (i + 1) - n - 1) * s[i];
  const mean = s.reduce((a, b) => a + b, 0) / n;
  return mean === 0 ? 0 : sum / (n * n * mean);
}

const mainVals = buildEngram('engram-main', 'main');
buildEngram('grid-factored', 'factored');
buildEngram('grid-patchwork', 'patchwork');

const gini = computeGini(mainVals);
const mass = Math.round(mainVals.reduce((a, b) => a + b, 0) * 1000);
document.getElementById('gini-val').textContent = gini.toFixed(2);
document.getElementById('mass-val').textContent = mass + 'g';
document.getElementById('bit-val').textContent = gini < 0.5 ? '1' : '0';

window.addEventListener('resize', () => {
  if (document.getElementById('panel-network').classList.contains('active')) drawNN();
});
setTimeout(drawNN, 50);
</script>

